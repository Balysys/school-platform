generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Role {
  ADMIN
  ENSEIGNANT
  PARENT
}

model Utilisateur {
  id           Int      @id @default(autoincrement())
  nom          String
  email        String   @unique
  mot_de_passe String
  role         Role     @default(PARENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  eleves       Eleve[]  @relation("ParentEleves")
  notes        Note[]   @relation("EnseignantNotes")
}

model Eleve {
  id             Int      @id @default(autoincrement())
  nom            String
  prenom         String
  dateNaissance  DateTime
  classeId       Int
  parentId       Int
  
  classe         Classe      @relation(fields: [classeId], references: [id])
  parent         Utilisateur @relation("ParentEleves", fields: [parentId], references: [id])
  notes          Note[]
}

model Classe {
  id        Int     @id @default(autoincrement())
  nom       String
  niveau    String
  
  eleves Eleve[]
}

model Matiere {
  id      Int     @id @default(autoincrement())
  nom     String
  coeff   Int     @default(1)
  
  notes Note[]
}

model Periode {
  id        Int     @id @default(autoincrement())
  libelle   String
  dateDebut DateTime
  dateFin   DateTime
  
  notes Note[]
}

model Note {
  id           Int      @id @default(autoincrement())
  eleveId      Int
  matiereId    Int
  periodeId    Int
  enseignantId Int
  valeur       Float
  dateCreation DateTime @default(now())
  
  eleve      Eleve      @relation(fields: [eleveId], references: [id])
  matiere    Matiere    @relation(fields: [matiereId], references: [id])
  periode    Periode    @relation(fields: [periodeId], references: [id])
  enseignant Utilisateur @relation("EnseignantNotes", fields: [enseignantId], references: [id])
}
